{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "PHP Built-in Server",
      "type": "php",
      "request": "launch",
      "runtimeArgs": [
        "-S",
        "localhost:8080",
        "-t",
        "${workspaceFolder}/backend/src",
        "-d",
        "xdebug.mode=debug",
        "-d",
        "xdebug.start_with_request=yes"
      ],
      "port": 9003
    },
    {
      "name": "Debug frontend",
      "cwd": "frontend",
      "request": "launch",
      "type": "dart"
    },
    {
      "name": "Profile frontend",
      "cwd": "frontend",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile"
    },
    {
      "name": "Release frontend",
      "cwd": "frontend",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release"
    }
  ]
}